CORTEXOS_ENV=production
CORTEXOS_HOST=127.0.0.1
CORTEXOS_PORT=8011
CORTEXOS_LOG_LEVEL=INFO
CORTEXOS_DATA_DIR=./data
CORTEXOS_DB_PATH=./data/cortexos.sqlite3
CORTEXOS_QDRANT_URL=http://127.0.0.1:6333
CORTEXOS_QDRANT_COLLECTION=cortexos_chunks
CORTEXOS_DENSE_VECTOR_NAME=dense
CORTEXOS_SPARSE_VECTOR_NAME=sparse
CORTEXOS_DENSE_DIM=1024
CORTEXOS_DEFAULT_MODEL=qwen3:8b
CORTEXOS_QUALITY_MODEL=qwen3:14b
CORTEXOS_CODE_MODEL=qwen3-coder-next:q4_K_M
CORTEXOS_OLLAMA_URL=http://127.0.0.1:11434
CORTEXOS_EMBEDDING_BACKEND=bge-m3
CORTEXOS_RERANK_BACKEND=bge-reranker-v2-m3
CORTEXOS_ENABLE_LLM_SYNTHESIS=true
CORTEXOS_ENABLE_QUERY_EXPANSION=false
CORTEXOS_ENABLE_PLAYWRIGHT=true
CORTEXOS_ENABLE_CRAWL4AI=true
CORTEXOS_ENABLE_DOCLING=true
CORTEXOS_ENABLE_SEARXNG=true
CORTEXOS_SEARXNG_URL=http://127.0.0.1:8787
CORTEXOS_DEFAULT_WING=general
CORTEXOS_DEFAULT_ROOM=inbox
CORTEXOS_CHUNK_SIZE=1200
CORTEXOS_CHUNK_OVERLAP=180
